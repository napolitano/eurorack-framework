    "eurorack",
    "modular-synthesizer",
    "embedded",
    "firmware",
    "hardware-abstraction",
    "controls",
    "cv",
    "gates",
    "triggers",
    "storage",
    "display"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/napolitano/eurorack-framework.git"
  },
