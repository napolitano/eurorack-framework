{
  "name": "eurorack-controls",
  "version": "0.1.0-alpha.28",
  "keywords": [
    "eurorack",
    "modular-synthesizer",
    "embedded",
    "firmware"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/napolitano/eurorack-framework.git"
  },
  "authors": [
    {
      "name": "Axel Napolitano",
      "email": "eurorack@skjt.de",
      "maintainer": true
    }
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/napolitano/eurorack-framework",
  "description": "Compatibility meta-library that selects every control model. Prefer individual eurorack-control-* libraries so unused buttons, LEDs, encoders, faders, and switches are not compiled.",
  "frameworks": "*",
  "platforms": "*",
  "build": {
    "includeDir": "include",
    "srcDir": "src"
  },
  "dependencies": {
    "eurorack-control-analog-input": "*",
    "eurorack-control-bicolor-led": "*",
    "eurorack-control-cv": "*",
    "eurorack-control-digital-led": "*",
    "eurorack-control-dip-switch": "*",
    "eurorack-control-encoder-value": "*",
    "eurorack-control-fader": "*",
    "eurorack-control-gate": "*",
    "eurorack-control-illuminated-button": "*",
    "eurorack-control-illuminated-fader": "*",
    "eurorack-control-momentary-button": "*",
    "eurorack-control-multicolor-led": "*",
    "eurorack-control-on-off-momentary-switch": "*",
    "eurorack-control-potentiometer": "*",
    "eurorack-control-rotary-encoder": "*",
    "eurorack-control-toggle-switch": "*"
  }
}
