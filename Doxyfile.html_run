PROJECT_NAME           = "Eurorack Framework"
PROJECT_NUMBER         = "Unreleased Alpha"
PROJECT_BRIEF          = "Portable C++ infrastructure for Eurorack module firmware"
OUTPUT_DIRECTORY = /home/claude/doxout
CREATE_SUBDIRS         = NO

INPUT                  = docs/manual docs/guides docs/architecture docs/release include src
FILE_PATTERNS          = *.hpp *.h *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = docs/manual/index.md

OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = NO
MULTILINE_CPP_IS_BRIEF = NO
TOC_INCLUDE_HEADINGS   = 5


EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SHOW_USED_FILES        = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE = /home/claude/doxout/warnings.log

GENERATE_HTML = YES
GENERATE_LATEX = NO
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = pdflatex
USE_PDFLATEX           = YES
PDF_HYPERLINKS         = YES
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
LATEX_HEADER           =
LATEX_FOOTER           =

GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF = NO
GENERATE_DOCBOOK       = NO

HAVE_DOT               = YES
UML_LOOK               = YES
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = png
INTERACTIVE_SVG        = NO

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCES_RELATION    = YES
REFERENCED_BY_RELATION = YES

EXCLUDE_PATTERNS       = */docs/generated/* */.pio/* */dist/*
BUILTIN_STL_SUPPORT    = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES

QUIET                  = NO
