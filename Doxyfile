PROJECT_NAME           = "Eurorack Framework"
PROJECT_NUMBER         = "Unreleased Alpha"
PROJECT_BRIEF          = "Portable C++ infrastructure for Eurorack module firmware"
OUTPUT_DIRECTORY       = docs/generated
CREATE_SUBDIRS         = NO

INPUT                  = docs/manual docs/guides docs/architecture docs/release docs/hardware libraries
FILE_PATTERNS          = *.hpp *.h *.cpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = docs/manual/index.md

OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = NO
MULTILINE_CPP_IS_BRIEF = NO
TOC_INCLUDE_HEADINGS   = 5


# EXTRACT_ALL must stay NO. When set to YES, Doxygen treats every entity as
# "documented" regardless of actual content, which silently disables
# WARN_IF_UNDOCUMENTED below. Do not re-enable without also removing the
# undocumented-entity warning from the quality gate.
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SHOW_USED_FILES        = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
# WARN_NO_PARAMDOC is intentionally disabled. It was verified (2026) to produce false
# "parameters/return type not documented" warnings for every function in this Doxygen 1.9.8
# build, even for minimal, fully documented reproductions with correct @param/@return blocks and
# no other diagnostics enabled. Per-parameter documentation completeness is instead enforced by
# tools/check-public-docs.py, which uses independent, non-Doxygen parsing and does not share this
# false-positive behavior.
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = YES
WARN_LOGFILE           = docs/generated/doxygen-warnings.log

GENERATE_HTML          = NO
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = pdflatex
USE_PDFLATEX           = YES
PDF_HYPERLINKS         = YES
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
LATEX_HEADER           =
LATEX_FOOTER           =

GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = YES
GENERATE_DOCBOOK       = NO

HAVE_DOT               = YES
UML_LOOK               = YES
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = png
INTERACTIVE_SVG        = NO

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCES_RELATION    = YES
REFERENCED_BY_RELATION = YES

EXCLUDE_PATTERNS       = */docs/generated/* */.pio/* */dist/*
# AVR interrupt vector definitions (the ISR() macro from avr/interrupt.h) are bare forwarding
# shims at file scope, not public API declared in include/; the project's own convention forbids
# Doxygen-style comment blocks in .cpp implementation code, so they are excluded here rather than
# documented in place. See adc_scanner3.cpp, external_edge_latch.cpp, and timer2_tick.cpp for the
# plain-comment explanation kept alongside each one.
EXCLUDE_SYMBOLS        = ISR*
BUILTIN_STL_SUPPORT    = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES

QUIET                  = NO
